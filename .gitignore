# Real flight BBL fixtures (large binary files)
src/main/blackbox/__fixtures__/*.bbl
src/main/blackbox/__fixtures__/*.bfl
# Keep test-fixtures/bbl/ tracked — one fixture for CI integration tests
# Additional fixtures can be added as needed for new test cases

