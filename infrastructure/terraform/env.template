# PIDlab Infrastructure Secrets — Template
# Copy to .env.local and fill in real values:
#   cp env.template .env.local
#
# Usage (manual terraform):
#   source .env.local
#   terraform init -backend-config=backend-dev.hcl   # or backend-prod.hcl
#   terraform apply -var-file=dev.tfvars              # or prod.tfvars
#
# Usage (point app to dev worker):
#   source .env.local
#   TELEMETRY_URL=$TELEMETRY_DEV_URL npm run dev

# ─── Terraform S3 Backend (R2 tfstate bucket) ──────────────────────
# CF token: pidlab-terraform-r2-v2 (Object Read & Write, All buckets)
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# ─── Terraform Provider (Cloudflare API) ───────────────────────────
# CF token: pidlab-infra-provisioning (Workers + R2 Edit)
export TF_VAR_cloudflare_api_token=""

# ─── Worker Secrets ────────────────────────────────────────────────
# Admin keys for /admin/stats/* endpoints (generate with: openssl rand -hex 32)
export TF_VAR_admin_key_dev=""
export TF_VAR_admin_key_prod=""

# Resend email delivery (resend.com → API Keys)
export TF_VAR_resend_api_key=""

# ─── License Worker Secrets ──────────────────────────────────────
# Ed25519 keypair for license signing (generate with: infrastructure/scripts/generate-ed25519-keypair.sh)
export TF_VAR_ed25519_private_key=""
export TF_VAR_ed25519_public_key=""

# License admin keys (generate with: openssl rand -hex 32)
export TF_VAR_license_admin_key_dev=""
export TF_VAR_license_admin_key_prod=""

# ─── Convenience aliases ───────────────────────────────────────────
export TELEMETRY_DEV_URL="https://pidlab-telemetry-dev.eddycek-ve.workers.dev/v1/collect"
export TELEMETRY_PROD_URL="https://pidlab-telemetry.eddycek-ve.workers.dev/v1/collect"
export PIDLAB_ADMIN_KEY_DEV=""
export PIDLAB_ADMIN_KEY_PROD=""
export PIDLAB_LICENSE_API_URL=""
export PIDLAB_LICENSE_ADMIN_KEY=""
