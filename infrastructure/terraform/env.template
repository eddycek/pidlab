# PIDlab — Terraform Environment
#
# Copy to .env.local:  cp env.template .env.local
# Only needed for manual terraform operations (CI/CD handles this automatically).
#
# Usage:
#   source .env.local
#   terraform init -backend-config=backend-dev.hcl
#   terraform apply -var-file=dev.tfvars

# ── R2 State Backend ────────────────────────────────────────────
# Terraform stores state in Cloudflare R2 (S3-compatible, hence AWS_ prefix)
# GitHub secrets: TERRAFORM_STATE_R2_ACCESS_KEY_ID, TERRAFORM_STATE_R2_SECRET_ACCESS_KEY
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# ── Cloudflare API Token ────────────────────────────────────────
# Scope: Workers, R2, D1, DNS Edit
# GitHub secret: CLOUDFLARE_PROVISIONING
export TF_VAR_cloudflare_api_token=""

# ── Telemetry Worker ────────────────────────────────────────────
# Set to dev or prod key depending on target environment
export TF_VAR_admin_key=""
export TF_VAR_resend_api_key=""

# ── License Worker ──────────────────────────────────────────────
export TF_VAR_license_admin_key=""
export TF_VAR_license_ed25519_private_key=""
export TF_VAR_license_ed25519_public_key=""
