# PIDlab Infrastructure Secrets — Template
# Copy to .env.local and fill in real values:
#   cp env.template .env.local
#
# Usage (manual terraform):
#   source .env.local
#   export TF_VAR_admin_key=$TF_VAR_admin_key_dev           # or _prod
#   export TF_VAR_license_admin_key=$TF_VAR_license_admin_key_dev  # or _prod
#   terraform init -backend-config=backend-dev.hcl           # or backend-prod.hcl
#   terraform apply -var-file=dev.tfvars                     # or prod.tfvars
#
# Usage (point app to dev worker):
#   source .env.local
#   TELEMETRY_URL=$TELEMETRY_DEV_URL npm run dev

# ═══════════════════════════════════════════════════════════════════
# TERRAFORM BACKEND (R2 tfstate bucket)
# ═══════════════════════════════════════════════════════════════════
# CF token: pidlab-terraform-r2-v2 (Object Read & Write, All buckets)
# GitHub secrets: TERRAFORM_STATE_R2_ACCESS_KEY_ID, TERRAFORM_STATE_R2_SECRET_ACCESS_KEY
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# ═══════════════════════════════════════════════════════════════════
# TERRAFORM PROVIDER (Cloudflare API)
# ═══════════════════════════════════════════════════════════════════
# CF token: pidlab-infra-provisioning (Workers + R2 + D1 + DNS Edit)
# GitHub secret: CLOUDFLARE_PROVISIONING
export TF_VAR_cloudflare_api_token=""

# ═══════════════════════════════════════════════════════════════════
# TELEMETRY WORKER SECRETS
# ═══════════════════════════════════════════════════════════════════
# Admin keys for /admin/stats/* endpoints (generate with: openssl rand -hex 32)
# GitHub secrets: TELEMETRY_ADMIN_KEY_DEV, TELEMETRY_ADMIN_KEY_PROD
# Terraform var: TF_VAR_admin_key (set from dev or prod below before apply)
export TF_VAR_admin_key_dev=""
export TF_VAR_admin_key_prod=""

# Resend email delivery for daily telemetry reports (resend.com → API Keys)
# GitHub secret: RESEND_API_KEY
export TF_VAR_resend_api_key=""

# ═══════════════════════════════════════════════════════════════════
# LICENSE WORKER SECRETS
# ═══════════════════════════════════════════════════════════════════
# Ed25519 keypair for license signing/verification
# Generate with: infrastructure/scripts/generate-ed25519-keypair.sh
# CRITICAL: Back up in 1Password — cannot be regenerated without invalidating all issued licenses
# GitHub secrets: LICENSE_ED25519_PRIVATE_KEY, LICENSE_ED25519_PUBLIC_KEY
# Public key is also bundled in src/shared/constants.ts → LICENSE.LICENSE_ED25519_PUBLIC_KEY
export TF_VAR_license_ed25519_private_key=""
export TF_VAR_license_ed25519_public_key=""

# License admin keys for /admin/keys/* endpoints (generate with: openssl rand -hex 32)
# GitHub secrets: LICENSE_ADMIN_KEY_DEV, LICENSE_ADMIN_KEY_PROD
# Terraform var: TF_VAR_license_admin_key (set from dev or prod below before apply)
export TF_VAR_license_admin_key_dev=""
export TF_VAR_license_admin_key_prod=""

# ═══════════════════════════════════════════════════════════════════
# CONVENIENCE ALIASES (for local scripts and dev)
# ═══════════════════════════════════════════════════════════════════
# Telemetry worker URLs
export TELEMETRY_DEV_URL="https://pidlab-telemetry-dev.eddycek-ve.workers.dev/v1/collect"
export TELEMETRY_PROD_URL="https://telemetry.pidlab.app/v1/collect"

# License worker URLs
export LICENSE_DEV_URL="https://pidlab-license-dev.eddycek-ve.workers.dev"
export LICENSE_PROD_URL="https://license.pidlab.app"

# Admin script env vars (infrastructure/scripts/*)
# Telemetry admin scripts
export PIDLAB_TELEMETRY_API_URL=""    # set to TELEMETRY_DEV_URL or TELEMETRY_PROD_URL
export PIDLAB_TELEMETRY_ADMIN_KEY=""  # set to TF_VAR_admin_key_dev or _prod

# License admin scripts
export PIDLAB_LICENSE_API_URL=""      # set to LICENSE_DEV_URL or LICENSE_PROD_URL
export PIDLAB_ADMIN_KEY=""            # set to TF_VAR_license_admin_key_dev or _prod
