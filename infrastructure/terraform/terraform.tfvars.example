# Copy to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars (it's in .gitignore).
#
# For dev:  environment = "dev"  → bucket: pidlab-telemetry-dev, worker: pidlab-telemetry-dev, no cron
# For prod: environment = "prod" → bucket: pidlab-telemetry, worker: pidlab-telemetry, cron 07:00 UTC

cloudflare_account_id = "your-account-id"
cloudflare_api_token  = "your-api-token"
environment           = "dev"

admin_key      = "your-admin-key"
resend_api_key = "re_xxxxxxxxxxxx"
report_email      = "you@example.com"
report_from_email = "onboarding@resend.dev"

# Custom domains — set zone_id for fpvpidlab.app zone
# Dev:  domain = "telemetry.dev.fpvpidlab.app", license_domain = "license.dev.fpvpidlab.app"
# Prod: domain = "telemetry.fpvpidlab.app",     license_domain = "license.fpvpidlab.app"
# domain         = "telemetry.fpvpidlab.app"
# license_domain = "license.fpvpidlab.app"
# zone_id        = "your-fpvpidlab-app-zone-id"
