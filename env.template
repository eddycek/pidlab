# PIDlab — Admin Scripts Environment
#
# Copy to .env.local:  cp env.template .env.local
# Scripts auto-load this file. No need to manually source it.
#
# Default: DEV environment
# Override: PIDLAB_ENV=prod ./infrastructure/scripts/generate-key.sh ...

# ── Worker URLs ──────────────────────────────────────────────────
TELEMETRY_DEV_URL="https://pidlab-telemetry-dev.eddycek-ve.workers.dev"
TELEMETRY_PROD_URL="https://telemetry.pidlab.app"
LICENSE_DEV_URL="https://pidlab-license-dev.eddycek-ve.workers.dev"
LICENSE_PROD_URL="https://license.pidlab.app"

# ── Telemetry Admin Keys ────────────────────────────────────────
# GitHub secrets: TELEMETRY_ADMIN_KEY_DEV, TELEMETRY_ADMIN_KEY_PROD
TELEMETRY_ADMIN_KEY_DEV=""
TELEMETRY_ADMIN_KEY_PROD=""

# ── License Admin Keys ──────────────────────────────────────────
# GitHub secrets: LICENSE_ADMIN_KEY_DEV, LICENSE_ADMIN_KEY_PROD
LICENSE_ADMIN_KEY_DEV=""
LICENSE_ADMIN_KEY_PROD=""

# ── Ed25519 Keypair (license signing) ───────────────────────────
# GitHub secrets: LICENSE_ED25519_PRIVATE_KEY, LICENSE_ED25519_PUBLIC_KEY
LICENSE_ED25519_PRIVATE_KEY=""
LICENSE_ED25519_PUBLIC_KEY=""
